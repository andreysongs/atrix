      "purpose": "any maskable"
    }
  ],
  "shortcuts": [
    {
      "name": "Iniciar treino",
      "short_name": "Treinar",
      "description": "Abra o Pulse pronto para começar um treino.",
      "url": "/?action=start-workout",
      "icons": [
        {
          "src": "/icons/icon-96.webp",
          "sizes": "96x96",
          "type": "image/webp"
        }
      ]
    },
    {
      "name": "Ver progresso",
      "short_name": "Progresso",
      "description": "Acompanhe sua evolução e suas metas.",
      "url": "/?view=progress",
      "icons": [
        {
          "src": "/icons/icon-96.webp",
          "sizes": "96x96",
          "type": "image/webp"
        }
      ]
    }
  ],
  "prefer_related_applications": false
